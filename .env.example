# GitHub Actions secrets (set in repo settings — Battatawada/crime)
NOTEBOOKLM_AUTH_JSON=
VPS_WEBHOOK_URL=http://140.245.245.123:8765
VPS_WEBHOOK_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
ALERT_WEBHOOK_URL=

# VPS-only
WEBHOOK_SECRET=
REFERENCE_IMAGES_DIR=./config/references
FLOWKIT_BASE_URL=http://127.0.0.1:8100
SCENE_DELAY_SECONDS=25
SCENE_MAX_RETRIES=3
RUNS_DIR=./runs
NICHE_HOST=0.0.0.0
NICHE_PORT=8765

# Phase 2 (defaults also in config/pipeline.json)
TTS_VOICE=en-US-AndrewMultilingualNeural
TTS_RATE=-6%
TTS_PROVIDER=azure
TTS_AZURE_STYLE_DEGREE=0.9

# Azure Speech (primary TTS; edge-tts used as fallback when unset or on failure)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia

# Phase 5 (defaults also in config/channel_rules.json upload section)
YOUTUBE_PRIVACY=public
YOUTUBE_CATEGORY_ID=24
YOUTUBE_MADE_FOR_KIDS=false
YOUTUBE_CONTAINS_SYNTHETIC_MEDIA=true

# Chrome → xray (Flow image gen through VPN IP; FlowKit stays on localhost)
# CHROME_NETWORK_MODE=proxy
# CHROME_PROXY=socks5://127.0.0.1:10808
# FLOW_403_FAILOVER=1
